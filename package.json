{
  "name": "wmts-capabilities",
  "version": "0.2.0",
  "description": "WMTS (Web Map Tile Service) Capabilities XML to JSON parser",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/wmts-capabilities.js",
  "module": "./dist/wmts-capabilities.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/wmts-capabilities.js",
      "require": "./dist/wmts-capabilities.umd.cjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/wmts-capabilities.js"
    }
  },
  "bin": {
    "wmtscapabilities": "bin/wmtscapabilities.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-russo/wmts-capabilities.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "^9.39.4",
    "prettier": "^3.0.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "gis",
    "wmts",
    "getcapabilities",
    "capabilities",
    "geoserver",
    "Web Map Tile Service",
    "xml",
    "json"
  ],
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/gabriel-russo/wmts-capabilities/issues"
  },
  "homepage": "https://github.com/gabriel-russo/wmts-capabilities"
}
