{
  "name": "wmts-capabilities",
  "version": "0.1.0",
  "description": "WMTS GetCapabilities XML to JSON parser, based on openlayers",
  "main": "dist/wmts-capabilities.min.js",
  "module": "dist/wmts-capabilities.mjs",
  "types": "index.d.ts",
  "bin": {
    "wmtscapabilities": "bin/wmtscapabilities"
  },
  "scripts": {
    "test": "node -r reify test/index.js | tap-spec",
    "start": "npm run watch-js",
    "watch-js": "rollup -cw",
    "build-js": "rollup -c",
    "build": "npm run build-js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/w8r/wmts-capabilities.git"
  },
  "devDependencies": {
    "@ampproject/rollup-plugin-closure-compiler": "^0.26.0",
    "@rollup/plugin-buble": "^0.21.3",
    "@rollup/plugin-commonjs": "^18.0.0",
    "@rollup/plugin-node-resolve": "^11.2.1",
    "reify": "^0.20.12",
    "rollup": "^2.45.2",
    "rollup-plugin-browsersync": "^1.3.1",
    "tap-spec": "^5.0.0",
    "tape": "^5.2.2",
    "xmldom": "^0.6.0"
  },
  "keywords": ["gis", "wmts", "getcapabilities", "xml", "json"],
  "author": "Alexander Milevski <info@w8r.name>",
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/w8r/wmts-capabilities/issues"
  },
  "homepage": "https://github.com/w8r/wmts-capabilities"
}
